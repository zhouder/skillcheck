{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://unpkg.com/skillcheck/schema/config.schema.json",
  "title": "Skillcheck configuration",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "ignore": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "rules": {
      "type": "object",
      "additionalProperties": {
        "enum": ["off", "info", "warning", "error"]
      }
    },
    "maxDepth": { "type": "integer", "minimum": 0, "maximum": 32 },
    "failOn": { "enum": ["error", "warning", "never"] }
  }
}
